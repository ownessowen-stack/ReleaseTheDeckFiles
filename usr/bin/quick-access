        wifi_header = tk.Frame(wifi_card, bg=self.colors['card_bg'])
        wifi_header.pack(fill=tk.X, padx=20, pady=(20, 10))
        tk.Label(wifi_header, text="WI-FI", font=self.font_bold,
                bg=self.colors['card_bg'], fg=self.colors['accent']).pack(side=tk.LEFT)
        current_wifi = self.network.current_wifi or "Not connected"
