                bg=self.colors['card_bg'], fg=self.colors['accent']).pack(side=tk.LEFT)
        bt_toggle_frame = tk.Frame(bt_card, bg=self.colors['card_bg'])
        bt_toggle_frame.pack(fill=tk.X, padx=20, pady=5)
        bt_status_text = "ON" if self.network.bluetooth_status else "OFF"
