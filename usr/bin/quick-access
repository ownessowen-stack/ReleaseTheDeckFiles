    def switch_wifi_view(self, view):
        self.current_network_view = view
        self.refresh_networks_display()
    
    def switch_bluetooth_view(self, view):
        self.current_bluetooth_view = view
        self.refresh_devices_display()
    
    def toggle_wifi(self):
        self.network.toggle_wifi()
        self.refresh_network_content()
    
    def toggle_bluetooth(self):
        self.network.toggle_bluetooth()
        self.refresh_network_content()
    
    def refresh_network_content(self):
        self.refresh_networks_display()
        self.refresh_devices_display()
    
    def refresh_networks_display(self):
        for widget in self.wifi_list_frame.winfo_children():
            widget.destroy()
        loading = tk.Label(self.wifi_list_frame, text="Loading...", font=self.font_small,
                           bg=self.colors['card_bg'], fg=self.colors['fg'])
        loading.pack()
        if self.current_network_view == "paired":
            try:
                result = subprocess.run(['nmcli', '-t', '-f', 'NAME,TYPE', 'connection', 'show'],
                                       capture_output=True, text=True, timeout=5)
                loading.destroy()
                found = False
                for line in result.stdout.strip().split('\n'):
                    if line and 'wifi' in line.lower():
                        parts = line.split(':')
                        if len(parts) >= 1 and parts[0]:
                            found = True
                            net_frame = tk.Frame(self.wifi_list_frame, bg=self.colors['card_bg'])
                            net_frame.pack(fill=tk.X, pady=2)
                            tk.Label(net_frame, text=f"📡 {parts[0]}", font=self.font_small,
                                    bg=self.colors['card_bg'], fg=self.colors['fg']).pack(side=tk.LEFT)
                            btn_frame = tk.Frame(net_frame, bg=self.colors['card_bg'])
                            btn_frame.pack(side=tk.RIGHT)
                            tk.Button(btn_frame, text="CONNECT", font=self.font_small,
                                      bg=self.colors['button_bg'], fg=self.colors['fg'],
                                      bd=0, padx=8, pady=2, cursor='hand2',
                                      activebackground=self.colors['button_hover'],
                                      command=lambda s=parts[0]: self.connect_wifi(s)).pack(side=tk.LEFT, padx=2)
                            tk.Button(btn_frame, text="FORGET", font=self.font_small,
                                      bg=self.colors['danger'], fg='white',
                                      bd=0, padx=8, pady=2, cursor='hand2',
                                      activebackground='#c0392b',
                                      command=lambda s=parts[0]: self.forget_wifi(s)).pack(side=tk.LEFT, padx=2)
                if not found:
                    tk.Label(self.wifi_list_frame, text="No saved networks", font=self.font_small,
                            bg=self.colors['card_bg'], fg=self.colors['fg']).pack()
            except:
                loading.destroy()
                tk.Label(self.wifi_list_frame, text="Error loading networks", font=self.font_small,
                        bg=self.colors['card_bg'], fg=self.colors['fg']).pack()
        else:
            self.network.scan_networks(callback=lambda nets: self.display_networks(nets))
    
    def display_networks(self, networks):
        for widget in self.wifi_list_frame.winfo_children():
            widget.destroy()
        if not networks:
            tk.Label(self.wifi_list_frame, text="No networks found", font=self.font_small,
                    bg=self.colors['card_bg'], fg=self.colors['fg']).pack()
            return
        for net in networks:
            net_frame = tk.Frame(self.wifi_list_frame, bg=self.colors['card_bg'])
            net_frame.pack(fill=tk.X, pady=2)
            signal_bars = "📶" if net['signal'] > 60 else "📡" if net['signal'] > 30 else "📴"
            lock = "🔒" if net['secured'] else "🔓"
            tk.Label(net_frame, text=f"{signal_bars} {lock} {net['ssid']} ({net['signal']}%)", font=self.font_small,
                    bg=self.colors['card_bg'], fg=self.colors['fg']).pack(side=tk.LEFT)
            tk.Button(net_frame, text="CONNECT", font=self.font_small,
                      bg=self.colors['button_bg'], fg=self.colors['fg'],
                      bd=0, padx=10, pady=2, cursor='hand2',
                      activebackground=self.colors['button_hover'],
                      command=lambda s=net['ssid'], sec=net['secured']: self.prompt_wifi_password(s, sec)).pack(side=tk.RIGHT)
    
    def prompt_wifi_password(self, ssid, secured):
        if not secured:
            self.connect_wifi(ssid)
            return
        dialog = tk.Toplevel(self.root)
        dialog.title("Wi-Fi Password")
        dialog.geometry("300x150")
        dialog.resizable(False, False)
        dialog.configure(bg=self.colors['bg'])
        dialog.transient(self.root)
        dialog.grab_set()
        tk.Label(dialog, text=f"Password for {ssid}:", font=self.font_semibold,
                bg=self.colors['bg'], fg=self.colors['fg']).pack(pady=10)
        password_entry = tk.Entry(dialog, show="*", font=('Arial', 12), width=25)
        password_entry.pack(pady=5)
        password_entry.focus()
        def connect():
            password = password_entry.get()
            if password:
                self.connect_wifi(ssid, password)
            dialog.destroy()
        tk.Button(dialog, text="CONNECT", font=self.font_semibold,
                  bg=self.colors['accent'], fg='#000000',
                  bd=0, padx=15, pady=5, cursor='hand2',
                  command=connect).pack(pady=10)
        dialog.bind('<Return>', lambda e: connect())
    
    def connect_wifi(self, ssid, password=None):
        self.network.connect_wifi(ssid, password)
        self.refresh_networks_display()
    
    def forget_wifi(self, ssid):
        self.network.forget_wifi(ssid)
        self.refresh_networks_display()
    
    def refresh_devices_display(self):
        for widget in self.bt_list_frame.winfo_children():
            widget.destroy()
        loading = tk.Label(self.bt_list_frame, text="Loading...", font=self.font_small,
                           bg=self.colors['card_bg'], fg=self.colors['fg'])
        loading.pack()
        if self.current_bluetooth_view == "paired":
            self.network.scan_bluetooth(callback=lambda devs: self.display_paired_devices(devs, loading))
        else:
            self.network.scan_available_bluetooth(callback=lambda devs: self.display_available_devices(devs, loading))
    
    def display_paired_devices(self, devices, loading):
        loading.destroy()
        if not devices:
            tk.Label(self.bt_list_frame, text="No paired devices", font=self.font_small,
                    bg=self.colors['card_bg'], fg=self.colors['fg']).pack()
            return
        for dev in devices:
            dev_frame = tk.Frame(self.bt_list_frame, bg=self.colors['card_bg'])
            dev_frame.pack(fill=tk.X, pady=2)
            status = "🔵" if dev['connected'] else "⚪"
            tk.Label(dev_frame, text=f"{status} {dev['name']}", font=self.font_small,
                    bg=self.colors['card_bg'], fg=self.colors['fg']).pack(side=tk.LEFT)
            btn_frame = tk.Frame(dev_frame, bg=self.colors['card_bg'])
            btn_frame.pack(side=tk.RIGHT)
            if dev['connected']:
                tk.Button(btn_frame, text="DISCONNECT", font=self.font_small,
                          bg=self.colors['button_bg'], fg=self.colors['fg'],
                          bd=0, padx=8, pady=2, cursor='hand2',
                          activebackground=self.colors['button_hover'],
                          command=lambda m=dev['mac']: self.disconnect_bluetooth(m)).pack(side=tk.LEFT, padx=2)
            else:
                tk.Button(btn_frame, text="CONNECT", font=self.font_small,
                          bg=self.colors['button_bg'], fg=self.colors['fg'],
                          bd=0, padx=8, pady=2, cursor='hand2',
                          activebackground=self.colors['button_hover'],
                          command=lambda m=dev['mac']: self.connect_bluetooth(m)).pack(side=tk.LEFT, padx=2)
            tk.Button(btn_frame, text="REMOVE", font=self.font_small,
                      bg=self.colors['danger'], fg='white',
                      bd=0, padx=8, pady=2, cursor='hand2',
                      activebackground='#c0392b',
                      command=lambda m=dev['mac']: self.remove_bluetooth(m)).pack(side=tk.LEFT, padx=2)
    
    def display_available_devices(self, devices, loading):
        loading.destroy()
        if not devices:
            tk.Label(self.bt_list_frame, text="No devices found", font=self.font_small,
                    bg=self.colors['card_bg'], fg=self.colors['fg']).pack()
            return
        for dev in devices:
            dev_frame = tk.Frame(self.bt_list_frame, bg=self.colors['card_bg'])
            dev_frame.pack(fill=tk.X, pady=2)
            tk.Label(dev_frame, text=f"🔄 {dev['name']} ({dev['mac']})", font=self.font_small,
                    bg=self.colors['card_bg'], fg=self.colors['fg']).pack(side=tk.LEFT)
            tk.Button(dev_frame, text="PAIR", font=self.font_small,
                      bg=self.colors['button_bg'], fg=self.colors['fg'],
                      bd=0, padx=8, pady=2, cursor='hand2',
                      activebackground=self.colors['button_hover'],
                      command=lambda m=dev['mac']: self.pair_bluetooth(m)).pack(side=tk.RIGHT)
    
    def pair_bluetooth(self, mac):
        self.network.pair_bluetooth(mac)
        self.refresh_devices_display()
    
    def connect_bluetooth(self, mac):
        self.network.connect_bluetooth(mac)
        self.refresh_devices_display()
    
    def disconnect_bluetooth(self, mac):
        self.network.disconnect_bluetooth(mac)
        self.refresh_devices_display()
    
    def remove_bluetooth(self, mac):
        self.network.remove_bluetooth(mac)
        self.refresh_devices_display()
    
    # ---------- TDP & FAN CONTENT (NO TEMPERATURES) ----------
    def create_tdp_content(self):
        title = tk.Label(self.content_scrollable, text="TDP & FAN CONTROL", font=self.font_black,
                        bg=self.colors['bg'], fg=self.colors['accent'])
        title.pack(pady=(0, 20))
        
        # TDP card
        tdp_card = tk.Frame(self.content_scrollable, bg=self.colors['card_bg'])
        tdp_card.pack(fill=tk.X, pady=10, padx=10)
        tk.Label(tdp_card, text="TDP MODE", font=self.font_bold,
                bg=self.colors['card_bg'], fg=self.colors['accent']).pack(anchor='w', padx=20, pady=(20, 10))
        self.current_tdp_label = tk.Label(tdp_card, text=self.power_manager.current_mode_name,
                                          font=self.font_medium,
                                          bg=self.colors['card_bg'], fg=self.colors['accent'])
        self.current_tdp_label.pack(pady=5)
        tdp_modes = [(0, "Console"), (1, "Handheld"), (2, "OC CPU"), (3, "OC GPU"),
                     (4, "OC All"), (5, "Perf All"), (6, "Perf OC All")]
        row1 = tk.Frame(tdp_card, bg=self.colors['card_bg'])
        row1.pack(fill=tk.X, pady=10, padx=20)
        for mode_id, name in tdp_modes[:4]:
            btn = tk.Button(row1, text=name, font=self.font_semibold,
                           bg=self.colors['button_bg'], fg=self.colors['fg'],
                           bd=0, padx=10, pady=6, cursor='hand2',
                           activebackground=self.colors['button_hover'],
                           command=lambda m=mode_id, n=name: self.set_tdp_mode(m, n))
            btn.pack(side=tk.LEFT, expand=True, fill=tk.X, padx=2)
            self._all_widgets.append(btn)
        row2 = tk.Frame(tdp_card, bg=self.colors['card_bg'])
        row2.pack(fill=tk.X, pady=5, padx=20)
        for mode_id, name in tdp_modes[4:]:
            btn = tk.Button(row2, text=name, font=self.font_semibold,
                           bg=self.colors['button_bg'], fg=self.colors['fg'],
                           bd=0, padx=10, pady=6, cursor='hand2',
                           activebackground=self.colors['button_hover'],
                           command=lambda m=mode_id, n=name: self.set_tdp_mode(m, n))
            btn.pack(side=tk.LEFT, expand=True, fill=tk.X, padx=2)
            self._all_widgets.append(btn)
        
        # Fan card
        fan_card = tk.Frame(self.content_scrollable, bg=self.colors['card_bg'])
        fan_card.pack(fill=tk.X, pady=10, padx=10)
        tk.Label(fan_card, text="FAN MODE", font=self.font_bold,
                bg=self.colors['card_bg'], fg=self.colors['accent']).pack(anchor='w', padx=20, pady=(20, 10))
        self.current_fan_label = tk.Label(fan_card, text=self.power_manager.current_fan,
                                          font=self.font_medium,
                                          bg=self.colors['card_bg'], fg=self.colors['accent'])
        self.current_fan_label.pack(pady=5)
        fan_row = tk.Frame(fan_card, bg=self.colors['card_bg'])
        fan_row.pack(fill=tk.X, pady=15, padx=20)
        for fan_mode in ["Console", "Handheld", "Cool"]:
            btn = tk.Button(fan_row, text=fan_mode, font=self.font_semibold,
                           bg=self.colors['button_bg'], fg=self.colors['fg'],
                           bd=0, padx=10, pady=6, cursor='hand2',
                           activebackground=self.colors['button_hover'],
                           command=lambda f=fan_mode: self.set_fan_mode(f))
            btn.pack(side=tk.LEFT, expand=True, fill=tk.X, padx=2)
            self._all_widgets.append(btn)
        tk.Frame(self.content_scrollable, bg=self.colors['bg'], height=20).pack()
    
    def set_tdp_mode(self, mode_id, name):
        def callback(success, new_name):
            if success:
                self.current_tdp_label.config(text=name)
                try:
                    subprocess.run(['notify-send', 'TDP', f'Switched to {name}',
                                  '-t', '2000'], stderr=subprocess.DEVNULL)
                except:
                    pass
        self.power_manager.set_mode_by_id_async(mode_id, callback)
    
    def set_fan_mode(self, fan_mode):
        def callback(success, new_mode):
            if success:
                self.current_fan_label.config(text=fan_mode)
                try:
                    subprocess.run(['notify-send', 'Fan', f'Switched to {fan_mode} fan',
                                  '-t', '2000'], stderr=subprocess.DEVNULL)
                except:
                    pass
        self.power_manager.set_fan_async(fan_mode, callback)
    
    # ---------- SCRIPTS CONTENT ----------
    def create_scripts_content(self):
        title = tk.Label(self.content_scrollable, text="SCRIPTS", font=self.font_black,
                        bg=self.colors['bg'], fg=self.colors['accent'])
        title.pack(pady=(0, 20))
        scripts_card = tk.Frame(self.content_scrollable, bg=self.colors['card_bg'])
        scripts_card.pack(fill=tk.X, pady=10, padx=10)
        scripts = [
            ("Lock Screen", "loginctl lock-session"),
            ("Screenshot", "gnome-screenshot -i"),
            ("Night Light", "redshift -O 3500"),
            ("Reset Night Light", "redshift -x"),
        ]
        for name, cmd in scripts:
            btn = tk.Button(scripts_card, text=name, font=self.font_semibold,
                           bg=self.colors['button_bg'], fg=self.colors['fg'],
                           bd=0, padx=20, pady=12, cursor='hand2',
                           activebackground=self.colors['button_hover'],
                           command=lambda c=cmd: self.run_command(c))
            btn.pack(fill=tk.X, pady=5, padx=20)
            self._all_widgets.append(btn)
        tk.Frame(self.content_scrollable, bg=self.colors['bg'], height=20).pack()
    
    # ---------- POWER CONTENT ----------
    def create_power_content(self):
        title = tk.Label(self.content_scrollable, text="POWER", font=self.font_black,
                        bg=self.colors['bg'], fg=self.colors['accent'])
        title.pack(pady=(0, 20))
        power_card = tk.Frame(self.content_scrollable, bg=self.colors['card_bg'])
        power_card.pack(fill=tk.X, pady=10, padx=10)
        power_options = [
            ("Suspend", "systemctl suspend", self.colors['button_bg']),
            ("Restart", "systemctl reboot", self.colors['close_btn']),
            ("Shutdown", "systemctl poweroff", self.colors['close_btn']),
        ]
        for name, cmd, color in power_options:
            btn = tk.Button(power_card, text=name, font=self.font_semibold,
                           bg=color, fg=self.colors['fg'],
                           bd=0, padx=20, pady=12, cursor='hand2',
                           activebackground=self.colors['button_hover'],
                           command=lambda c=cmd: self.run_command(c))
            btn.pack(fill=tk.X, pady=5, padx=20)
            self._all_widgets.append(btn)
        tk.Frame(self.content_scrollable, bg=self.colors['bg'], height=20).pack()
    
    # ---------- UTILITIES ----------
    def create_slider(self, parent, from_, to, value, command):
        frame = tk.Frame(parent, bg=self.colors['card_bg'])
        frame.pack(fill=tk.X, pady=10, padx=20)
        slider = tk.Scale(frame, from_=from_, to=to, orient=tk.HORIZONTAL,
                         length=450, width=35, sliderlength=50, showvalue=False,
                         bg=self.colors['card_bg'], fg=self.colors['fg'],
                         troughcolor=self.colors['slider_bg'],
                         activebackground=self.colors['accent'],
                         highlightbackground=self.colors['border'],
                         highlightthickness=0, bd=0,
                         command=command)
        slider.set(value)
        slider.pack(fill=tk.X)
        self._all_widgets.append(slider)
        return slider
    
    def get_brightness(self):
        try:
            result = subprocess.run(['brightnessctl', 'get'], capture_output=True, text=True, timeout=2)
            if result.stdout:
                current = int(result.stdout.strip())
                max_result = subprocess.run(['brightnessctl', 'max'], capture_output=True, text=True, timeout=2)
                if max_result.stdout:
                    max_val = int(max_result.stdout.strip())
                    return int((current / max_val) * 100)
        except:
            pass
        return self.config.get('brightness', 100)
    
    def set_brightness(self, value):
        try:
            value = int(value)
            value = max(1, min(100, value))
            subprocess.run(['brightnessctl', 'set', f'{value}%'], check=True, capture_output=True, timeout=2)
            self.bright_slider.set(value)
            self.bright_label.config(text=f"{value}%")
            self.config['brightness'] = value
        except:
            pass
    
    def get_volume(self):
        try:
            result = subprocess.run(['pactl', 'get-sink-volume', '@DEFAULT_SINK@'],
                                   capture_output=True, text=True, timeout=2)
            if '%' in result.stdout:
                match = re.search(r'(\d+)%', result.stdout)
                if match:
                    return float(match.group(1))
        except:
            pass
        return self.config.get('volume', 50)
    
    def set_volume(self, value):
        try:
            value = int(value)
            self.vol_slider.set(value)
            self.vol_label.config(text=f"{value}%")
            subprocess.run(['pactl', 'set-sink-volume', '@DEFAULT_SINK@', f'{value}%'],
                         check=True, capture_output=True, timeout=2)
            self.config['volume'] = value
            if value == 0:
                self.mute_btn.config(text="UNMUTE")
            else:
                self.mute_btn.config(text="MUTE")
        except:
            pass
    
    def toggle_mute(self):
        try:
            check = subprocess.run(['pactl', 'get-sink-mute', '@DEFAULT_SINK@'],
                                 capture_output=True, text=True, timeout=2)
            subprocess.run(['pactl', 'set-sink-mute', '@DEFAULT_SINK@', 'toggle'],
                         check=True, capture_output=True, timeout=2)
            if 'yes' in check.stdout.lower():
                self.mute_btn.config(text="MUTE")
            else:
                self.mute_btn.config(text="UNMUTE")
        except:
            pass
    
    def run_command(self, command):
        try:
            logging.info(f"Running: {command}")
            subprocess.Popen(command, shell=True)
        except:
            pass
    
    def on_content_configure(self, event):
        self.content_canvas.configure(scrollregion=self.content_canvas.bbox('all'))
    
    def on_content_canvas_configure(self, event):
        self.content_canvas.itemconfig(self.content_canvas_frame, width=event.width)
    
    def _bind_content_mousewheel(self, event):
        self.content_canvas.bind_all('<MouseWheel>', self._on_content_mousewheel)
    
    def _unbind_content_mousewheel(self, event):
        self.content_canvas.unbind_all('<MouseWheel>')
    
    def _on_content_mousewheel(self, event):
        self.content_canvas.yview_scroll(int(-1*(event.delta/120)), 'units')
    
    def load_config(self):
        self.config = {}
        if self.config_file.exists():
            try:
                with open(self.config_file, 'r') as f:
                    self.config = json.load(f)
            except:
                pass
    
    def save_config(self):
        try:
            self.config_file.parent.mkdir(parents=True, exist_ok=True)
            with open(self.config_file, 'w') as f:
                json.dump(self.config, f, indent=2)
        except:
            pass

# ==================== MAIN ====================
def check_lock_file():
    try:
        lock_fd = open(LOCK_FILE, 'w')
        try:
            fcntl.flock(lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
            return lock_fd, False
        except BlockingIOError:
            lock_fd.close()
            return None, True
    except:
        return None, False

def release_lock(lock_fd):
    try:
        if lock_fd:
            fcntl.flock(lock_fd, fcntl.LOCK_UN)
            lock_fd.close()
            try:
                os.unlink(LOCK_FILE)
            except:
                pass
    except:
        pass

def main():
    logging.info("=" * 50)
    logging.info("Quick Access Menu starting up")
    lock_fd, already_running = check_lock_file()
    if already_running:
        logging.info("Another instance is already running. Killing it and exiting.")
        try:
            if LOCK_FILE.exists():
                with open(LOCK_FILE, 'r') as f:
                    old_pid = f.read().strip()
                    if old_pid and old_pid.isdigit():
                        old_pid = int(old_pid)
                        try:
                            os.kill(old_pid, signal.SIGTERM)
                            time.sleep(0.2)
                        except:
                            pass
        except:
            pass
        sys.exit(0)
    try:
        lock_fd.write(str(os.getpid()))
        lock_fd.flush()
    except:
        pass
    suspender = AppSuspender()
    power_manager = PowerModeManager()
    root = tk.Tk()
    app = QuickAccessMenu(root, suspender, power_manager)
    root.after(100, app.update_game_info)
    root.update_idletasks()
    root.update()
    time.sleep(0.15)
    suspended, _ = suspender.suspend_focused_app()
    if suspended:
        logging.info("Game suspended with controller blocking")
        app.update_game_info()
        app.force_input_grab()
        root.after(100, app.force_input_grab)
        root.after(300, app.force_input_grab)
        root.after(500, app.force_input_grab)
        root.lift()
        root.focus_force()
        root.attributes('-topmost', True)
    try:
        root.mainloop()
    except Exception as e:
        logging.error(f"Error: {e}")
    finally:
        suspender.resume_app()
        release_lock(lock_fd)
        logging.info("Quick Access Menu closed")
    logging.info("=" * 50)

if __name__ == "__main__":
    main()
