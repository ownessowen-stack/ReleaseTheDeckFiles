    'PS Vita': 'Vita3K --fullscreen "{file.path}"',
    'Xbox': 'xemu -full-screen -disk "{file.path}"',
    'Sega Dreamcast': 'flycast --fullscreen --exit "{file.path}"',
    'Nintendo DS': 'melonDS -f "{file.path}"',
    'Game Boy Advance': 'mGBA-qt -f "{file.path}"',
    'Unknown': 'echo "No emulator configured for this platform"',
}

